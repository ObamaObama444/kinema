{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/profile",
      "destination": "/app/profile",
      "permanent": false
    },
    {
      "source": "/goals",
      "destination": "/app/profile",
      "permanent": false
    },
    {
      "source": "/app/goals",
      "destination": "/app/profile",
      "permanent": false
    },
    {
      "source": "/app/exercises",
      "destination": "/app/catalog",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "http://127.0.0.1:8000/health"
    },
    {
      "source": "/api/:path*",
      "destination": "http://127.0.0.1:8000/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "http://127.0.0.1:8000/static/:path*"
    },
    {
      "source": "/login",
      "destination": "http://127.0.0.1:8000/login"
    },
    {
      "source": "/register",
      "destination": "http://127.0.0.1:8000/register"
    },
    {
      "source": "/app",
      "destination": "http://127.0.0.1:8000/app"
    },
    {
      "source": "/app/:path*",
      "destination": "http://127.0.0.1:8000/app/:path*"
    }
  ]
}
